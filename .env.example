# Copy to .env and fill in real credentials. .env is gitignored.
# Rotate the live values regularly and never commit them.

DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
# Optional — only needed if you want the app to auto-refresh access tokens:
DHAN_PIN=
DHAN_TOTP_SECRET=

# Runtime
VOLSCALP_MODE=paper          # paper | live (UI can override)
VOLSCALP_LOG_LEVEL=INFO
VOLSCALP_DATA_DIR=./data
VOLSCALP_DASHBOARD_HOST=127.0.0.1
VOLSCALP_DASHBOARD_PORT=8765
